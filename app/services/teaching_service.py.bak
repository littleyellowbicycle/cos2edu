from typing import List, Dict, Optional, AsyncIterator, Tuple, Any
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select, delete
from app.core.database import Conversation, Character, Material, ModelConfig, Message
from app.core.config import settings
from app.core.logging_config import get_logger
from app.schemas import MessageCreate
from app.services.crud_services import MessageService, ModelConfigService, ConversationService
from app.services.llm_providers import get_provider
from app.services.history_manager import history_manager, HistorySummaryGenerator

logger = get_logger(__name__)


class TeachingService:
    SOCRATIC_PROMPT = """你是一位精通苏格拉底教学法的导师。苏格拉底教学法的核心是：
1. 不直接给出答案，而是通过精心设计的问题引导学生自己思考
2. 从学生已知的知识出发，逐步引导到新的知识
3. 鼓励学生质疑、推理、验证
4. 当学生犯错时，通过反问让他们自己发现错误

请始终遵循以下规则：
- 绝对不要直接给出答案或完整的解释
- 每次用1-2个引导性问题来推进学习
- 问题要循序渐进，从简单到复杂
- 密切关注学生的回答，根据他们的理解程度调整问题
- 保持耐心和鼓励的态度
- 当学生得出正确结论时，给予肯定并提出下一个更深层次的问题

你的性格设定：
{personality}

{background}

请用中文与学生交流。"""

    EXPLANATION_PROMPT = """你是一位知识渊博、善于讲解的导师。你的教学风格是：
1. 用通俗易懂的语言解释复杂概念
2. 多举例子帮助理解
3. 结构清晰，逻辑严谨
4. 鼓励学生提问

你的性格设定：
{personality}

{background}

请用中文与学生交流。"""

    MIXED_PROMPT = """你是一位灵活多变的导师。你会根据学习内容和学生的情况，灵活运用苏格拉底式提问和直接讲解：
- 对于新概念和需要深度理解的内容，使用苏格拉底式提问引导
- 对于需要快速了解的背景知识，可以直接讲解
- 保持互动，关注学生的反馈

你的性格设定：
{personality}

{background}

请用中文与学生交流。"""

    @staticmethod
    def build_system_prompt(
        character: Character,
        material: Optional[Material],
        teaching_mode: str
    ) -> str:
        personality = character.personality
        background = character.background or ""
        
        if teaching_mode == "socratic":
            base_prompt = TeachingService.SOCRATIC_PROMPT
        elif teaching_mode == "explanation":
            base_prompt = TeachingService.EXPLANATION_PROMPT
        else:
            base_prompt = TeachingService.MIXED_PROMPT
        
        system_prompt = base_prompt.format(
            personality=personality,
            background=f"背景故事：{background}" if background else ""
        )
        
        if material:
            material_context = f"\n\n当前学习的教材内容：\n{material.content}\n"
            system_prompt += material_context
        
        return system_prompt

    @staticmethod
    async def build_chat_messages(
        db: AsyncSession,
        conversation: Conversation,
        user_message: str,
        return_removed: bool = False
    ) -> Any:
        character = conversation.character
        material = conversation.material
        teaching_mode = conversation.teaching_mode
        
        system_prompt = TeachingService.build_system_prompt(
            character, material, teaching_mode
        )
        
        history_messages = await MessageService.get_by_conversation(db, conversation.id)
        history_dicts = [{"role": msg.role, "content": msg.content} for msg in history_messages]
        
        model_name = None
        default_config = await ModelConfigService.get_default(db)
        if default_config:
            model_name = default_config.model_name
        
        if return_removed:
            messages, removed_messages, stats = history_manager.build_messages_for_llm(
                system_prompt=system_prompt,
                history_messages=history_dicts,
                user_message=user_message,
                model=model_name,
                return_removed=True
            )
            return messages, removed_messages, stats
        else:
            messages = history_manager.build_messages_for_llm(
                system_prompt=system_prompt,
                history_messages=history_dicts,
                user_message=user_message,
                model=model_name
            )
            return messages

    @staticmethod
    async def _should_regenerate_full_summary(
        removed_count: int,
        existing_covered_count: int,
        strategy: str,
        threshold: float
    ) -> Tuple[bool, str]:
        """
        决定是否需要重新生成完整摘要
        
        Returns:
            (是否需要重新生成, 原因)
        """
        if strategy == "full":
            return True, "策略配置为始终重新生成完整摘要"
        
        if existing_covered_count == 0:
            return True, "没有已有摘要，需要生成新摘要"
        
        if removed_count == existing_covered_count:
            return False, "消息数完全匹配，使用已有摘要"
        
        if removed_count > existing_covered_count:
            if strategy == "incremental":
                return False, f"策略为增量更新，新增 {removed_count - existing_covered_count} 条消息"
            else:
                diff_ratio = (removed_count - existing_covered_count) / existing_covered_count
                if diff_ratio > threshold:
                    return True, f"差异比例 {diff_ratio:.2%} 超过阈值 {threshold:.0%}，重新生成完整摘要"
                return False, f"差异比例 {diff_ratio:.2%} 在阈值内，尝试增量更新"
        
        if removed_count < existing_covered_count:
            return True, f"消息数减少 ({existing_covered_count} -> {removed_count})，可能消息被删除，重新生成完整摘要"
        
        return False, "默认使用已有摘要"
    
    @staticmethod
    async def _generate_full_summary(
        removed_messages: List[Dict],
        model_config: Optional[ModelConfig],
        db: AsyncSession
    ) -> Optional[str]:
        """生成完整摘要"""
        return await HistorySummaryGenerator.generate_summary(
            messages=removed_messages,
            model_config=model_config,
            db=db
        )
    
    @staticmethod
    async def _generate_incremental_summary(
        existing_summary: str,
        new_messages: List[Dict],
        model_config: Optional[ModelConfig],
        db: AsyncSession
    ) -> Optional[str]:
        """生成增量摘要（合并已有摘要和新增消息）
        
        Returns:
            成功返回更新后的摘要，失败返回 None
        """
        if not new_messages:
            logger.debug("没有新增消息，无需增量更新")
            return None
        
        combined_for_summary = HistorySummaryGenerator.format_history_for_summary(new_messages)
        
        update_prompt = f"""以下是之前对话的摘要：
{existing_summary}

---

以下是新增的对话内容（需要合并到摘要中）：
{combined_for_summary}

---

请将以上两部分内容合并，生成一个完整的、更新后的对话摘要。要求：
1. 保留所有关键信息
2. 保持简洁（200-300字）
3. 按时间顺序组织内容

请生成更新后的摘要："""
        
        if not model_config:
            from app.services.crud_services import ModelConfigService
            model_config = await ModelConfigService.get_default(db)
        
        if not model_config:
            logger.warning("无法获取模型配置，增量更新失败")
            return None
        
        from app.services.llm_providers import get_provider
        try:
            provider = get_provider(
                provider_name=model_config.provider,
                api_key=model_config.api_key,
                base_url=model_config.base_url
            )
            
            updated_summary = await provider.chat(
                messages=[{"role": "user", "content": update_prompt}],
                model=model_config.model_name,
                temperature=settings.SUMMARY_TEMPERATURE,
                max_tokens=settings.SUMMARY_MAX_TOKENS
            )
            
            if updated_summary and len(updated_summary.strip()) > 0:
                logger.info(f"增量摘要更新成功，新长度: {len(updated_summary.strip())} 字符")
                return updated_summary.strip()
            else:
                logger.warning("增量更新摘要失败，返回空")
                return None
        except Exception as e:
            logger.error(f"增量更新摘要时出错: {e}", exc_info=True)
            return None
    
    @staticmethod
    async def build_chat_messages_with_summary(
        db: AsyncSession,
        conversation: Conversation,
        user_message: str,
        model_config: Optional[ModelConfig] = None
    ) -> List[Dict[str, str]]:
        """
        构建带摘要的消息列表
        
        摘要管理策略：
        1. 检测消息截断状态
        2. 检查摘要一致性（处理消息被直接删除的情况）
        3. 根据配置策略决定如何更新摘要
        4. 持久化保存摘要
        """
        messages, removed_messages, stats = await TeachingService.build_chat_messages(
            db=db,
            conversation=conversation,
            user_message=user_message,
            return_removed=True
        )
        
        if not stats.get("truncated", False) or not removed_messages:
            logger.debug("无消息被截断，无需生成摘要")
            return messages
        
        removed_count = len(removed_messages)
        existing_summary = conversation.summary
        existing_covered_count = conversation.summary_covered_message_count or 0
        
        logger.info(
            f"检测到历史消息截断: removed={removed_count}, "
            f"existing_summary={'有' if existing_summary else '无'}, "
            f"existing_covered_count={existing_covered_count}, "
            f"ENABLE_HISTORY_SUMMARY={settings.ENABLE_HISTORY_SUMMARY}"
        )
        
        if existing_summary and removed_count != existing_covered_count:
            logger.warning(
                f"摘要覆盖数不一致! removed_count={removed_count}, "
                f"existing_covered_count={existing_covered_count}. "
                f"这可能是因为消息被直接删除或其他外部操作。"
            )
        
        if not settings.ENABLE_HISTORY_SUMMARY:
            logger.debug("历史摘要功能未启用，跳过摘要生成")
            
            if existing_summary:
                summary_message = {
                    "role": "system",
                    "content": f"【历史对话摘要】\n{existing_summary}\n\n以上是之前对话的关键内容摘要，请基于此继续当前对话。"
                }
                if len(messages) > 1:
                    messages.insert(1, summary_message)
                else:
                    messages.append(summary_message)
                logger.info("已加载并使用已有摘要（摘要功能未启用但有保存的摘要）")
            
            return messages
        
        final_summary = None
        new_covered_count = existing_covered_count
        summary_was_updated = False
        
        if existing_summary:
            strategy = settings.SUMMARY_UPDATE_STRATEGY
            threshold = settings.SUMMARY_AUTO_THRESHOLD
            
            should_regenerate, reason = await TeachingService._should_regenerate_full_summary(
                removed_count=removed_count,
                existing_covered_count=existing_covered_count,
                strategy=strategy,
                threshold=threshold
            )
            
            logger.info(f"摘要更新决策: strategy={strategy}, regenerate={should_regenerate}, reason={reason}")
            
            if should_regenerate:
                logger.info(f"重新生成完整摘要: removed_count={removed_count}")
                generated_summary = await TeachingService._generate_full_summary(
                    removed_messages=removed_messages,
                    model_config=model_config,
                    db=db
                )
                
                if generated_summary:
                    final_summary = generated_summary
                    new_covered_count = removed_count
                    summary_was_updated = True
                    logger.info("完整摘要生成成功")
                else:
                    logger.warning("完整摘要生成失败，使用已有摘要作为降级方案")
                    final_summary = existing_summary
            else:
                if removed_count > existing_covered_count:
                    start_index = min(existing_covered_count, len(removed_messages))
                    if start_index < 0:
                        start_index = 0
                    
                    new_removed_messages = removed_messages[start_index:]
                    
                    logger.info(
                        f"尝试增量更新: existing_covered_count={existing_covered_count}, "
                        f"start_index={start_index}, new_messages_count={len(new_removed_messages)}"
                    )
                    
                    if new_removed_messages:
                        generated_summary = await TeachingService._generate_incremental_summary(
                            existing_summary=existing_summary,
                            new_messages=new_removed_messages,
                            model_config=model_config,
                            db=db
                        )
                        
                        if generated_summary:
                            final_summary = generated_summary
                            new_covered_count = removed_count
                            summary_was_updated = True
                        else:
                            logger.warning("增量更新失败，使用已有摘要")
                            final_summary = existing_summary
                    else:
                        logger.debug("没有新增消息，直接使用已有摘要")
                        final_summary = existing_summary
                else:
                    logger.debug(f"使用已有摘要: removed_count={removed_count}")
                    final_summary = existing_summary
        else:
            logger.info(f"没有已有摘要，生成新摘要: removed_count={removed_count}")
            
            generated_summary = await TeachingService._generate_full_summary(
                removed_messages=removed_messages,
                model_config=model_config,
                db=db
            )
            
            if generated_summary:
                logger.info(f"新摘要生成成功，长度: {len(generated_summary)} 字符")
                final_summary = generated_summary
                new_covered_count = removed_count
                summary_was_updated = True
            else:
                logger.warning("新摘要生成失败或返回空")
        
        if final_summary:
            summary_changed = (final_summary != existing_summary)
            covered_count_changed = (new_covered_count != existing_covered_count)
            needs_save = summary_changed or covered_count_changed
            
            if needs_save:
                from app.services.crud_services import ConversationService
                await ConversationService.save_summary(
                    db=db,
                    conversation_id=conversation.id,
                    summary=final_summary,
                    covered_message_count=new_covered_count
                )
                logger.info(
                    f"摘要已持久化保存: covered_count={new_covered_count}, "
                    f"summary_changed={summary_changed}, "
                    f"covered_count_changed={covered_count_changed}"
                )
                
                summary_message = {
                    "role": "system",
                    "content": f"【历史对话摘要】\n{final_summary}\n\n以上是之前对话的关键内容摘要，请基于此继续当前对话。"
                }
                
                if len(messages) > 1:
                    messages.insert(1, summary_message)
                else:
                    messages.append(summary_message)
                
                logger.debug(f"已将摘要插入消息列表，当前消息数: {len(messages)}")
            else:
                logger.debug("摘要和覆盖数均未变化，跳过插入摘要消息")
        
        return messages


class TitleGeneratorService:
    TITLE_GENERATION_PROMPT = """你是一个对话标题生成器。根据用户的第一条消息，生成一个简洁、有意义的对话标题。

规则：
1. 标题应该简洁（10-20字最佳，最多30字）
2. 标题应该准确概括对话主题
3. 不要使用问句形式
4. 直接输出标题，不要加引号或其他装饰

用户消息：
{message}

请生成标题："""

    @staticmethod
    async def generate_title(
        db: AsyncSession,
        user_message: str,
        model_config: Optional[ModelConfig] = None
    ) -> Optional[str]:
        if not model_config:
            model_config = await ModelConfigService.get_default(db)
            if not model_config:
                return None
        
        try:
            messages = [{
                "role": "user",
                "content": TitleGeneratorService.TITLE_GENERATION_PROMPT.format(message=user_message)
            }]
            
            provider = get_provider(
                provider_name=model_config.provider,
                api_key=model_config.api_key,
                base_url=model_config.base_url
            )
            
            title = await provider.chat(
                messages=messages,
                model=model_config.model_name,
                temperature=0.3,
                max_tokens=50
            )
            
            title = title.strip().strip('"').strip("'").strip()
            
            if title and len(title) > 0 and len(title) <= 50:
                return title
            return None
        except Exception as e:
            logger.warning(f"生成标题失败: {e}", exc_info=True)
            return None


class ChatService:
    @staticmethod
    async def chat(
        db: AsyncSession,
        conversation_id: int,
        user_message: str,
        model_config: Optional[ModelConfig] = None
    ) -> str:
        conversation = await ConversationService.get_by_id(db, conversation_id)
        if not conversation:
            raise ValueError(f"对话不存在: {conversation_id}")
        
        if not model_config:
            model_config = await ModelConfigService.get_default(db)
            if not model_config:
                raise ValueError("未配置模型，请先在设置中配置模型")
        
        existing_messages = await MessageService.get_by_conversation(db, conversation_id)
        is_first_message = len(existing_messages) == 0
        
        await MessageService.create(db, conversation_id, MessageCreate(
            role="user",
            content=user_message
        ))
        
        messages = await TeachingService.build_chat_messages_with_summary(
            db=db,
            conversation=conversation,
            user_message=user_message,
            model_config=model_config
        )
        
        provider = get_provider(
            provider_name=model_config.provider,
            api_key=model_config.api_key,
            base_url=model_config.base_url
        )
        
        response = await provider.chat(
            messages=messages,
            model=model_config.model_name,
            temperature=0.7,
            max_tokens=2000
        )
        
        await MessageService.create(db, conversation_id, MessageCreate(
            role="assistant",
            content=response
        ))
        
        if is_first_message and (not conversation.title or conversation.title == "新对话"):
            generated_title = await TitleGeneratorService.generate_title(
                db=db,
                user_message=user_message,
                model_config=model_config
            )
            if generated_title:
                from app.schemas import ConversationUpdate
                await ConversationService.update(
                    db=db,
                    conversation_id=conversation_id,
                    conversation=ConversationUpdate(title=generated_title)
                )
        
        return response

    @staticmethod
    async def chat_stream(
        db: AsyncSession,
        conversation_id: int,
        user_message: str,
        model_config: Optional[ModelConfig] = None
    ) -> AsyncIterator[str]:
        conversation = await ConversationService.get_by_id(db, conversation_id)
        if not conversation:
            raise ValueError(f"对话不存在: {conversation_id}")
        
        if not model_config:
            model_config = await ModelConfigService.get_default(db)
            if not model_config:
                raise ValueError("未配置模型，请先在设置中配置模型")
        
        existing_messages = await MessageService.get_by_conversation(db, conversation_id)
        is_first_message = len(existing_messages) == 0
        
        user_message_id = None
        try:
            db_user_message = await MessageService.create(db, conversation_id, MessageCreate(
                role="user",
                content=user_message
            ))
            user_message_id = db_user_message.id
            
            messages = await TeachingService.build_chat_messages_with_summary(
                db=db,
                conversation=conversation,
                user_message=user_message,
                model_config=model_config
            )
            
            provider = get_provider(
                provider_name=model_config.provider,
                api_key=model_config.api_key,
                base_url=model_config.base_url
            )
            
            full_response = ""
            async for chunk in provider.chat_stream(
                messages=messages,
                model=model_config.model_name,
                temperature=0.7,
                max_tokens=2000
            ):
                full_response += chunk
                yield chunk
            
            await MessageService.create(db, conversation_id, MessageCreate(
                role="assistant",
                content=full_response
            ))
            
            if is_first_message and (not conversation.title or conversation.title == "新对话"):
                generated_title = await TitleGeneratorService.generate_title(
                    db=db,
                    user_message=user_message,
                    model_config=model_config
                )
                if generated_title:
                    from app.schemas import ConversationUpdate
                    await ConversationService.update(
                        db=db,
                        conversation_id=conversation_id,
                        conversation=ConversationUpdate(title=generated_title)
                    )
        except Exception as e:
            if user_message_id:
                try:
                    await db.execute(
                        delete(Message).filter(Message.id == user_message_id)
                    )
                    await db.commit()
                except Exception as rollback_error:
                    logger.error(f"回滚用户消息失败: {rollback_error}", exc_info=True)
            raise e
