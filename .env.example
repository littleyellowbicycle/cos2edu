# ==========================================
#  苏格拉底AI教学系统 - 环境配置
# ==========================================

# ==========================================
#  Docker 部署配置
# ==========================================
# 容器运行的用户 ID 和组 ID（用于权限匹配）
# 可以通过 `id -u` 和 `id -g` 查看当前用户的 ID
# UID=1000
# GID=1000

# 应用对外暴露的端口
# APP_PORT=8000

# ==========================================
#  应用配置
# ==========================================
APP_NAME=苏格拉底AI教学系统
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000

# 环境设置 (dev/prod/test)
APP_ENV=prod
DEBUG=false
LOG_LEVEL=INFO

# ==========================================
#  数据目录配置
# ==========================================
DATA_DIR=./data
CHARACTERS_DIR=./data/characters
MATERIALS_DIR=./data/materials
CONVERSATIONS_DIR=./data/conversations
UPLOADS_DIR=./data/uploads
AVATARS_DIR=./data/uploads/avatars
BACKGROUNDS_DIR=./data/uploads/backgrounds

# ==========================================
#  上传配置
# ==========================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ==========================================
#  默认模型配置
# ==========================================
DEFAULT_MODEL=gpt-4o
DEFAULT_PROVIDER=openai

# ==========================================
#  OpenAI 配置
# ==========================================
OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=

# ==========================================
#  Anthropic 配置
# ==========================================
# ANTHROPIC_API_KEY=

# ==========================================
#  其他模型提供商配置（根据需要启用）
# ==========================================
# DASHSCOPE_API_KEY=
# ZHIPU_API_KEY=
# DOUBAO_API_KEY=
# DOUBAO_BASE_URL=
# WENXIN_API_KEY=
# WENXIN_BASE_URL=
# HUNYUAN_API_KEY=
# HUNYUAN_BASE_URL=
# MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=
# GEMINI_API_KEY=
# GEMINI_BASE_URL=

# ==========================================
#  Redis 配置（用于限流，可选）
# ==========================================
# 启用 Redis 限流需要设置 RATE_LIMIT_STORAGE=redis
# 并配置以下参数（使用 Docker Compose 部署时保持默认即可）
# REDIS_URL=redis://redis:6379/0
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# 限流存储 (memory 或 redis)
RATE_LIMIT_STORAGE=memory

# ==========================================
#  历史记录配置
# ==========================================
MAX_HISTORY_MESSAGES=20
MAX_HISTORY_TOKENS=4000
TOKEN_ESTIMATION_RATIO=1.3
USE_TIKTOKEN=true
TIKTOKEN_DEFAULT_MODEL=gpt-4

# ==========================================
#  历史摘要配置
# ==========================================
ENABLE_HISTORY_SUMMARY=false
SUMMARY_MAX_TOKENS=500
SUMMARY_TEMPERATURE=0.3

# ==========================================
#  VIP 配置
# ==========================================
MAX_HISTORY_MESSAGES_VIP=50
MAX_HISTORY_TOKENS_VIP=8000

# ==========================================
#  CORS 配置
# ==========================================
# 生产环境请修改为实际的域名
CORS_ALLOW_ORIGINS=http://localhost,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ==========================================
#  数据库配置
# ==========================================
DATABASE_URL=sqlite:///./data/app_prod.db
